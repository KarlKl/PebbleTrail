{
  "name": "pebble-trail",
  "author": "Karl",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.0"
  },
  "pebble": {
    "capabilities": [
      "location",
      "configurable"
    ],
